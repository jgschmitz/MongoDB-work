{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim837",
  "description": "HIPAA 837 Institutional Healthcare Claim document schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim", "id", "metadata", "trackingStatuses"],
  "properties": {
    "claim": { "$ref": "#/$defs/Claim" },
    "id": { "type": "string", "description": "Unique document identifier" },
    "metadata": { "$ref": "#/$defs/Metadata" },
    "trackingStatuses": {
      "type": "array",
      "items": { "$ref": "#/$defs/TrackingStatus" },
      "description": "Consider maxItems cap or archiving old statuses to prevent unbounded growth"
    }
  },
  "$defs": {
    "Address": {
      "type": "object",
      "additionalProperties": false,
      "description": "Standard postal address (shared across all address objects)",
      "properties": {
        "address1": { "type": "string" },
        "address2": { "type": ["string", "null"], "default": null },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "postalCode": { "type": "string" }
      },
      "required": ["address1", "city", "state", "postalCode"]
    },
    "Communication": {
      "type": "object",
      "additionalProperties": false,
      "description": "Communication channel (TE=telephone, FX=fax, EM=email)",
      "properties": {
        "type": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["type", "value"]
    },
    "ReferenceIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "description": "Shared ref identifier - replaces TaxInfo, ClaimIdIntermediaries, MedicalRecordNumber, PayerClaimControlNumber, PriorAuthorizationNumber, AutoAccidentState, DemonstrationProject, LineItemControlNumber, OtherPayerClaimControlNumber, OtherPayerPriorAuthorizationNumber",
      "properties": {
        "refId": { "type": "string" },
        "refType": { "type": "string" }
      },
      "required": ["refId", "refType"]
    },
    "HccCode": {
      "type": "object",
      "additionalProperties": false,
      "description": "HCC/diagnosis code - shared across admittingDiagnosisInfo, conditionInfo, drgInfo, patientReasonForVisit",
      "properties": {
        "code": { "type": "string" },
        "qualifierCode": { "type": "string" }
      },
      "required": ["code", "qualifierCode"]
    },
    "HccCodeWithResponse": {
      "type": "object",
      "additionalProperties": false,
      "description": "HCC code with optional response - for principalDiagnosisInfo, otherDiagnosisInfo, externalCauseOfInjury",
      "properties": {
        "code": { "type": "string" },
        "qualifierCode": { "type": "string" },
        "responseCode": { "type": ["string", "null"], "default": null }
      },
      "required": ["code", "qualifierCode"]
    },
    "HccCodeWithDate": {
      "type": "object",
      "additionalProperties": false,
      "description": "HCC code with date - for principalProcedureInfo, otherProcedureInfo, occurrenceInfo",
      "properties": {
        "code": { "type": "string" },
        "qualifierCode": { "type": "string" },
        "dateTimePeriodType": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }
      },
      "required": ["code", "qualifierCode", "dateTimePeriodType", "startDate"]
    },
    "HccCodeWithDateRange": {
      "type": "object",
      "additionalProperties": false,
      "description": "HCC code with date range - for occurrenceSpanInfo",
      "properties": {
        "code": { "type": "string" },
        "qualifierCode": { "type": "string" },
        "dateTimePeriodType": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      },
      "required": ["code", "qualifierCode", "dateTimePeriodType", "startDate", "endDate"]
    },
    "HccCodeWithAmount": {
      "type": "object",
      "additionalProperties": false,
      "description": "HCC code with monetary amount - for valueInfo",
      "properties": {
        "code": { "type": "string" },
        "qualifierCode": { "type": "string" },
        "monetaryAmount": { "type": "number", "description": "Changed from string to number" }
      },
      "required": ["code", "qualifierCode", "monetaryAmount"]
    },
    "HccCodeSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Wrapper for array of basic HCC codes",
      "properties": {
        "hccInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/HccCode" }
        }
      },
      "required": ["hccInfo"]
    },
    "HccCodeWithResponseSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Wrapper for array of HCC codes with response",
      "properties": {
        "hccInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/HccCodeWithResponse" }
        }
      },
      "required": ["hccInfo"]
    },
    "HccCodeWithDateSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Wrapper for array of HCC codes with dates",
      "properties": {
        "hccInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/HccCodeWithDate" }
        }
      },
      "required": ["hccInfo"]
    },
    "HccCodeWithDateRangeSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Wrapper for array of HCC codes with date ranges",
      "properties": {
        "hccInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/HccCodeWithDateRange" }
        }
      },
      "required": ["hccInfo"]
    },
    "HccCodeWithAmountSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Wrapper for array of HCC codes with amounts",
      "properties": {
        "hccInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/HccCodeWithAmount" }
        }
      },
      "required": ["hccInfo"]
    },
    "AdjustmentDetail": {
      "type": "object",
      "additionalProperties": false,
      "description": "Single adjustment triplet - normalized from numbered amount1/reasonCode1/quantity1",
      "properties": {
        "reasonCode": { "type": "string" },
        "amount": { "type": "number", "description": "Changed from string to number" },
        "quantity": { "type": ["number", "null"], "default": null, "description": "Changed from string to number" }
      },
      "required": ["reasonCode", "amount"]
    },
    "AmountWithType": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number", "description": "Changed from string to number" },
        "amountType": { "type": "string" }
      },
      "required": ["amount", "amountType"]
    },
    "OrganizationEntity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Organization entity - consolidates BillingProviderName, ReceiverInfoName, SubmitterInfoName, PayerInfoName, ServiceFacilityName, OtherPayerName",
      "properties": {
        "entityCategory": { "type": "string" },
        "entityId": { "type": "string" },
        "entityIdType": { "type": "string" },
        "entityType": { "type": "string" },
        "lastOrOrgName": { "type": "string" }
      },
      "required": ["entityCategory", "entityId", "entityIdType", "entityType", "lastOrOrgName"]
    },
    "PersonEntity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Person entity - consolidates AttendingPhysicianName, OperatingPhysicianName, OtherOperatingPhysicianName, RenderingProviderName, SubscriberName, OtherSubscriberName",
      "properties": {
        "entityCategory": { "type": "string" },
        "entityId": { "type": "string" },
        "entityIdType": { "type": "string" },
        "entityType": { "type": "string" },
        "firstName": { "type": "string" },
        "lastOrOrgName": { "type": "string" },
        "middleName": { "type": ["string", "null"], "default": null, "description": "Made optional everywhere (was inconsistently required in RenderingProviderName and PatientName)" },
        "nameSuffix": { "type": ["string", "null"], "default": null }
      },
      "required": ["entityCategory", "entityId", "entityIdType", "entityType", "firstName", "lastOrOrgName"]
    },
    "SimpleEntity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Simple entity with category and type only (PayToAddressName)",
      "properties": {
        "entityCategory": { "type": "string" },
        "entityType": { "type": "string" }
      },
      "required": ["entityCategory", "entityType"]
    },
    "PatientName": {
      "type": "object",
      "additionalProperties": false,
      "description": "Patient name entity - no entityId/entityIdType",
      "properties": {
        "entityCategory": { "type": "string" },
        "entityType": { "type": "string" },
        "firstName": { "type": "string" },
        "lastOrOrgName": { "type": "string" },
        "middleName": { "type": ["string", "null"], "default": null, "description": "Made optional (was required in original)" }
      },
      "required": ["entityCategory", "entityType", "firstName", "lastOrOrgName"]
    },
    "DemographicInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Shared demographic info - consolidates PatientDemographicInfo and SubscriberDemographicInfo (identical structures)",
      "properties": {
        "birthDate": { "type": "string", "format": "date", "description": "Changed from plain string to date format" },
        "genderCode": {
          "type": "string",
          "enum": ["M", "F", "U"],
          "description": "Added enum constraint"
        },
        "qualifier": { "type": "string" }
      },
      "required": ["birthDate", "genderCode", "qualifier"]
    },
    "SpecialtyInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provider specialty info (fixed typo: was specialityInfo)",
      "properties": {
        "refId": { "type": "string" },
        "refIdType": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["refId", "refIdType", "type"]
    },
    "NamedContactInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Contact info with name and normalized communications array (was communication1/communication2)",
      "properties": {
        "communications": {
          "type": "array",
          "items": { "$ref": "#/$defs/Communication" },
          "minItems": 1,
          "maxItems": 3
        },
        "functionCode": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["communications", "functionCode", "name"]
    },

    "Metadata": {
      "type": "object",
      "additionalProperties": false,
      "description": "Document-level metadata for the 837 claim",
      "properties": {
        "batchId": { "type": "string" },
        "batchTotalTransactionCount": { "type": ["integer", "null"], "default": null, "description": "Fixed: type now allows null" },
        "documentType": { "type": "string" },
        "payerId": { "type": "string", "description": "Note: also appears in metadata.properties.payerId - consider deduplicating" },
        "processDateCT": { "type": "integer", "description": "Process date as epoch timestamp" },
        "processState": { "type": "string" },
        "properties": { "$ref": "#/$defs/MetadataProperties" },
        "status": { "type": "string" },
        "tenantId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Changed to date-time format" },
        "transactionId": { "type": "string" },
        "transactionSeq": { "type": "integer" }
      },
      "required": ["batchId", "documentType", "payerId", "processDateCT", "processState", "properties", "status", "tenantId", "timestamp", "transactionId", "transactionSeq"]
    },
    "MetadataProperties": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isEligibleForClaimRemitMatch": { "type": "boolean", "description": "Changed from string to boolean" },
        "payer": { "type": "string" },
        "payerExportEligible": { "type": "boolean", "description": "Changed from string to boolean" },
        "payerId": { "type": "string", "description": "Redundant with metadata.payerId - consider removing" },
        "serviceEndDate": { "type": ["string", "null"], "format": "date", "default": null, "description": "Fixed casing: was serviceEnddate" },
        "serviceStartDate": { "type": ["string", "null"], "format": "date", "default": null, "description": "Fixed casing: was serviceStartdate" },
        "sourceSystem": { "type": "string" },
        "statusCode": { "type": "string" },
        "statusDescription": { "type": "string" },
        "statusTimestamp": { "type": "string", "format": "date-time", "description": "Changed to date-time format" }
      },
      "required": ["isEligibleForClaimRemitMatch", "payer", "payerExportEligible", "payerId", "sourceSystem", "statusCode", "statusDescription", "statusTimestamp"]
    },

    "TrackingStatus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "payerClaimControlNumber": { "type": ["string", "null"], "default": null },
        "statusCode": { "type": "string" },
        "statusDescription": { "type": "string" },
        "statusDetailType": { "type": "string" },
        "statusTrackingDate": { "type": "string", "format": "date-time", "description": "Changed to date-time format" },
        "trackingStatusDetail": {
          "anyOf": [
            { "$ref": "#/$defs/TrackingStatusDetail" },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["statusCode", "statusDescription", "statusDetailType", "statusTrackingDate"]
    },
    "TrackingStatusDetail": {
      "type": "object",
      "additionalProperties": false,
      "description": "Most fields made optional - they only apply to remit-matched statuses, not earlier lifecycle stages",
      "properties": {
        "checkNumber": { "type": ["string", "null"], "default": null, "description": "Made optional (only relevant for matched claims)" },
        "claimFilingIndicator": { "type": ["string", "null"], "default": null },
        "claimPaymentId": { "type": ["string", "null"], "default": null, "description": "Made optional" },
        "claimStatusCode": { "type": ["string", "null"], "default": null },
        "loadId": { "type": ["string", "null"], "default": null },
        "matchType": { "type": ["string", "null"], "default": null },
        "processDateCT": { "type": ["integer", "null"], "default": null },
        "remittanceStatus": { "type": ["string", "null"], "default": null },
        "totalCharge": { "type": ["number", "null"], "default": null, "description": "Changed from string to number" },
        "totalPaid": { "type": ["number", "null"], "default": null, "description": "Changed from string to number" },
        "type": { "type": "string" }
      },
      "required": ["type"]
    },

    "Claim": {
      "type": "object",
      "additionalProperties": false,
      "description": "The 837 claim transaction content",
      "properties": {
        "billingProvider": { "$ref": "#/$defs/BillingProvider" },
        "claimDetail": { "$ref": "#/$defs/ClaimDetail" },
        "headerInfo": { "$ref": "#/$defs/HeaderInfo" },
        "patient": {
          "anyOf": [
            { "$ref": "#/$defs/Patient" },
            { "type": "null" }
          ],
          "default": null
        },
        "subscriber": { "$ref": "#/$defs/Subscriber" },
        "transactionType": { "type": "string" }
      },
      "required": ["billingProvider", "claimDetail", "headerInfo", "subscriber", "transactionType"]
    },

    "BillingProvider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address" },
        "contactInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedContactInfo" },
          "description": "Uses shared NamedContactInfo with normalized communications array"
        },
        "name": { "$ref": "#/$defs/OrganizationEntity" },
        "payToAddress": { "$ref": "#/$defs/PayToAddress" },
        "specialtyInfo": { "$ref": "#/$defs/SpecialtyInfo", "description": "Fixed typo: was specialityInfo" },
        "taxInfo": { "$ref": "#/$defs/ReferenceIdentifier", "description": "Uses shared ReferenceIdentifier" }
      },
      "required": ["address", "contactInfo", "name", "payToAddress", "specialtyInfo", "taxInfo"]
    },
    "PayToAddress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address" },
        "name": { "$ref": "#/$defs/SimpleEntity" }
      },
      "required": ["address", "name"]
    },

    "Patient": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address" },
        "demographicInfo": { "$ref": "#/$defs/DemographicInfo" },
        "name": { "$ref": "#/$defs/PatientName" },
        "patientInfo": { "$ref": "#/$defs/PatientInfo" }
      },
      "required": ["address", "demographicInfo", "name", "patientInfo"]
    },
    "PatientInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relationshipCode": { "type": "string" }
      },
      "required": ["relationshipCode"]
    },

    "Subscriber": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address", "description": "Fixed typo: was 'addresss' (triple s)" },
        "demographicInfo": {
          "anyOf": [
            { "$ref": "#/$defs/DemographicInfo" },
            { "type": "null" }
          ],
          "default": null
        },
        "name": { "$ref": "#/$defs/PersonEntity" },
        "payerInfo": { "$ref": "#/$defs/SubscriberPayerInfo" },
        "subscriberInfo": { "$ref": "#/$defs/SubscriberInfo" }
      },
      "required": ["address", "name", "payerInfo", "subscriberInfo"]
    },
    "SubscriberPayerInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "anyOf": [
            { "$ref": "#/$defs/Address" },
            { "type": "null" }
          ],
          "default": null
        },
        "name": { "$ref": "#/$defs/OrganizationEntity" }
      },
      "required": ["name"]
    },
    "SubscriberInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claimFilingIndicatorCode": { "type": "string" },
        "groupOrPlanName": { "type": ["string", "null"], "default": null },
        "groupOrPolicyNumber": { "type": ["string", "null"], "default": null },
        "payerSeqCode": {
          "type": "string",
          "description": "P=Primary, S=Secondary, T=Tertiary"
        },
        "relationshipCode": { "type": ["string", "null"], "default": null }
      },
      "required": ["claimFilingIndicatorCode", "payerSeqCode"]
    },

    "ClaimDetail": {
      "type": "object",
      "additionalProperties": false,
      "description": "The main claim detail section with diagnosis, procedures, service lines, etc.",
      "properties": {
        "admission": {
          "anyOf": [
            { "$ref": "#/$defs/Admission" },
            { "type": "null" }
          ],
          "default": null
        },
        "admittingDiagnosisInfo": {
          "anyOf": [
            { "$ref": "#/$defs/HccCodeSet" },
            { "type": "null" }
          ],
          "default": null
        },
        "attendingPhysician": { "$ref": "#/$defs/AttendingPhysician" },
        "autoAccidentState": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "billingNote": {
          "anyOf": [
            { "$ref": "#/$defs/NoteDetail" },
            { "type": "null" }
          ],
          "default": null
        },
        "claimCode": { "$ref": "#/$defs/ClaimCode" },
        "claimIdIntermediaries": { "$ref": "#/$defs/ReferenceIdentifier" },
        "claimInfo": { "$ref": "#/$defs/ClaimInfo" },
        "claimNotes": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/NoteDetail" } },
            { "type": "null" }
          ],
          "default": null
        },
        "conditionInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeSet" } },
            { "type": "null" }
          ],
          "default": null
        },
        "demonstrationProject": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "dischargeHour": {
          "anyOf": [
            { "$ref": "#/$defs/DateWithFormat" },
            { "type": "null" }
          ],
          "default": null
        },
        "drgInfo": {
          "anyOf": [
            { "$ref": "#/$defs/HccCodeSet" },
            { "type": "null" }
          ],
          "default": null
        },
        "externalCauseOfInjury": {
          "anyOf": [
            { "$ref": "#/$defs/HccCodeWithResponseSet" },
            { "type": "null" }
          ],
          "default": null
        },
        "medicalRecordNumber": { "$ref": "#/$defs/ReferenceIdentifier" },
        "occurrenceInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeWithDateSet" } },
            { "type": "null" }
          ],
          "default": null
        },
        "occurrenceSpanInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeWithDateRangeSet" } },
            { "type": "null" }
          ],
          "default": null
        },
        "operatingPhysician": {
          "anyOf": [
            { "$ref": "#/$defs/PhysicianRef" },
            { "type": "null" }
          ],
          "default": null
        },
        "otherDiagnosisInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeWithResponseSet" } },
            { "type": "null" }
          ],
          "default": null
        },
        "otherOperatingPhysician": {
          "anyOf": [
            { "$ref": "#/$defs/PhysicianRef" },
            { "type": "null" }
          ],
          "default": null
        },
        "otherProcedureInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeWithDateSet" } },
            { "type": "null" }
          ],
          "default": null
        },
        "otherSubscriberInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/OtherSubscriberInfo" } },
            { "type": "null" }
          ],
          "default": null
        },
        "patientReasonForVisit": {
          "anyOf": [
            { "$ref": "#/$defs/HccCodeSet" },
            { "type": "null" }
          ],
          "default": null
        },
        "payerClaimControlNumber": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "principalDiagnosisInfo": { "$ref": "#/$defs/HccCodeWithResponseSet" },
        "principalProcedureInfo": {
          "anyOf": [
            { "$ref": "#/$defs/HccCodeWithDateSet" },
            { "type": "null" }
          ],
          "default": null
        },
        "priorAuthorizationNumber": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "renderingProvider": {
          "anyOf": [
            { "$ref": "#/$defs/PhysicianRef" },
            { "type": "null" }
          ],
          "default": null
        },
        "serviceFacility": {
          "anyOf": [
            { "$ref": "#/$defs/ServiceFacility" },
            { "type": "null" }
          ],
          "default": null
        },
        "serviceLines": {
          "type": "array",
          "items": { "$ref": "#/$defs/ServiceLine" }
        },
        "statementDates": { "$ref": "#/$defs/StatementDates" },
        "valueInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/HccCodeWithAmountSet" } },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["attendingPhysician", "claimCode", "claimIdIntermediaries", "claimInfo", "medicalRecordNumber", "principalDiagnosisInfo", "serviceLines", "statementDates"]
    },

    "Admission": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formatType": { "type": "string" },
        "qualifier": { "type": "string" }
      },
      "required": ["formatType", "qualifier"]
    },

    "AttendingPhysician": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/PersonEntity" },
        "providerSpecialtyInfo": {
          "anyOf": [
            { "$ref": "#/$defs/SpecialtyInfo" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Fixed typo: was providerSpecialityInfo"
        },
        "secondaryIdentifiers": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/ReferenceIdentifier" } },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["name"]
    },

    "PhysicianRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Shared physician reference - consolidates OperatingPhysician, OtherOperatingPhysician, RenderingProvider",
      "properties": {
        "name": { "$ref": "#/$defs/PersonEntity" }
      },
      "required": ["name"]
    },

    "ClaimCode": {
      "type": "object",
      "additionalProperties": false,
      "description": "CL1 segment - Institutional claim code",
      "properties": {
        "admissionSource": { "type": "string", "description": "UB-04 admission source code" },
        "admissionType": { "type": "string", "description": "UB-04 admission type code" },
        "patientStatus": { "type": "string", "description": "UB-04 patient discharge status code" }
      },
      "required": ["admissionSource", "admissionType", "patientStatus"]
    },

    "ClaimInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "CLM segment - Claim information",
      "properties": {
        "acceptAssignment": { "type": "string" },
        "assignmentOfBenefits": { "type": "string" },
        "claimFrequencyCode": { "type": "string" },
        "facilityCodeType": { "type": "string" },
        "facilityTypeCode": { "type": "string" },
        "patientAccountNumber": { "type": "string" },
        "releaseOfInformation": { "type": "string" },
        "totalCharge": { "type": "number", "description": "Changed from string to number" }
      },
      "required": ["acceptAssignment", "assignmentOfBenefits", "claimFrequencyCode", "facilityCodeType", "facilityTypeCode", "patientAccountNumber", "releaseOfInformation", "totalCharge"]
    },

    "NoteDetail": {
      "type": "object",
      "additionalProperties": false,
      "description": "Shared note structure - consolidates BillingNote and ClaimNotesItem (identical structures)",
      "properties": {
        "details": { "type": "string" },
        "referenceCode": { "type": "string" }
      },
      "required": ["details", "referenceCode"]
    },

    "DateWithFormat": {
      "type": "object",
      "additionalProperties": false,
      "description": "Date with format type and qualifier (for dischargeHour, admission dates, etc.)",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "formatType": { "type": "string" },
        "qualifier": { "type": "string" }
      },
      "required": ["date", "formatType", "qualifier"]
    },

    "StatementDates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endDate": { "type": "string", "format": "date" },
        "formatType": { "type": "string" },
        "qualifier": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }
      },
      "required": ["endDate", "formatType", "qualifier", "startDate"]
    },

    "ServiceFacility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address", "description": "Uses shared Address - address2 now properly optional (was required in original)" },
        "name": { "$ref": "#/$defs/OrganizationEntity" }
      },
      "required": ["address", "name"]
    },

    "ServiceLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assignedNumber": { "type": "string" },
        "drugIdentification": {
          "anyOf": [
            { "$ref": "#/$defs/DrugIdentification" },
            { "type": "null" }
          ],
          "default": null
        },
        "institutionalService": { "$ref": "#/$defs/InstitutionalService" },
        "lineAdjudicationInfo": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/LineAdjudicationInfo" } },
            { "type": "null" }
          ],
          "default": null
        },
        "lineItemControlNumber": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "renderingProviderName": {
          "anyOf": [
            { "$ref": "#/$defs/PhysicianRef" },
            { "type": "null" }
          ],
          "default": null
        },
        "serviceDate": {
          "anyOf": [
            { "$ref": "#/$defs/ServiceDate" },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["assignedNumber", "institutionalService"]
    },

    "DrugIdentification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drugUnitCount": { "type": "number", "description": "Changed from string to number" },
        "measurementCodeBasis": { "type": "string" },
        "productOrServiceId": { "type": "string" },
        "productOrServiceType": { "type": "string" }
      },
      "required": ["drugUnitCount", "measurementCodeBasis", "productOrServiceId", "productOrServiceType"]
    },

    "InstitutionalService": {
      "type": "object",
      "additionalProperties": false,
      "description": "SV2 segment - Institutional service line",
      "properties": {
        "description": { "type": ["string", "null"], "default": null },
