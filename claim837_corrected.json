          "type": "array",
          "items": { "type": "string" },
          "maxItems": 4,
          "description": "Normalized from hcpcsModifier1/hcpcsModifier2 into array"
        },
        "lineItemChargeAmount": { "type": "number", "description": "Changed from string to number" },
        "nonCoveredChargeAmount": { "type": ["number", "null"], "default": null, "description": "Changed from string to number" },
        "procedureCode": { "type": ["string", "null"], "default": null },
        "productIdQualifier": { "type": ["string", "null"], "default": null },
        "serviceLineRevenueCode": { "type": "string" },
        "unitCount": { "type": "number", "description": "Changed from string to number" },
        "unitOfMeasurement": { "type": "string" }
      },
      "required": ["lineItemChargeAmount", "serviceLineRevenueCode", "unitCount", "unitOfMeasurement"]
    },

    "LineAdjudicationInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adjudicationDate": { "$ref": "#/$defs/DateWithFormat" },
        "adjustments": {
          "type": "array",
          "items": { "$ref": "#/$defs/LineAdjustment" },
          "description": "Normalized adjustment items"
        },
        "lineAdjudicationInfo": { "$ref": "#/$defs/LineAdjudicationDetail" },
        "remainingPatientLiability": {
          "anyOf": [
            { "$ref": "#/$defs/AmountWithType" },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["adjudicationDate", "adjustments", "lineAdjudicationInfo"]
    },

    "LineAdjustment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Line-level CAS - normalized from numbered fields",
      "properties": {
        "groupCode": {
          "type": "string",
          "enum": ["CO", "PR", "OA", "PI", "CR"]
        },
        "details": {
          "type": "array",
          "items": { "$ref": "#/$defs/AdjustmentDetail" },
          "minItems": 1,
          "maxItems": 6
        }
      },
      "required": ["groupCode", "details"]
    },

    "LineAdjudicationDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "medicalProcedure": { "$ref": "#/$defs/MedicalProcedure" },
        "paidUnitsOfService": { "type": "number", "description": "Changed from string to number" },
        "payerIdentifier": { "type": "string" },
        "serviceLinePaidAmount": { "type": "number", "description": "Changed from string to number" },
        "serviceLineRevenueCode": { "type": "string" }
      },
      "required": ["medicalProcedure", "paidUnitsOfService", "payerIdentifier", "serviceLinePaidAmount", "serviceLineRevenueCode"]
    },

    "MedicalProcedure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modifier": { "type": ["string", "null"], "default": null, "description": "Renamed from modifier1" },
        "serviceId": { "type": ["string", "null"], "default": null },
        "serviceIdType": { "type": ["string", "null"], "default": null }
      }
    },

    "ServiceDate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formatType": { "type": "string" },
        "qualifier": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }
      },
      "required": ["formatType", "qualifier", "startDate"]
    },

    "OtherSubscriberInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "remainingPatientLiability": {
          "anyOf": [
            { "$ref": "#/$defs/AmountWithType" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Fixed casing: was RemainingPatientLiability (PascalCase)"
        },
        "claimLevelAdjustments": {
          "anyOf": [
            { "type": "array", "items": { "$ref": "#/$defs/OtherSubscriberAdjustment" } },
            { "type": "null" }
          ],
          "default": null
        },
        "cobPayerPaidAmount": {
          "anyOf": [
            { "$ref": "#/$defs/AmountWithType" },
            { "type": "null" }
          ],
          "default": null
        },
        "medicareOutpatientAdjudicationInfo": {
          "anyOf": [
            { "$ref": "#/$defs/MedicareOutpatientAdjudicationInfo" },
            { "type": "null" }
          ],
          "default": null
        },
        "otherInsuranceCoverageInfo": { "$ref": "#/$defs/OtherInsuranceCoverageInfo" },
        "otherPayer": { "$ref": "#/$defs/OtherPayer" },
        "otherSubscriber": { "$ref": "#/$defs/OtherSubscriber" },
        "subscriberInfo": { "$ref": "#/$defs/OtherSubscriberSubscriberInfo" }
      },
      "required": ["otherInsuranceCoverageInfo", "otherPayer", "otherSubscriber", "subscriberInfo"]
    },

    "OtherSubscriberAdjustment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Normalized from numbered fields",
      "properties": {
        "groupCode": {
          "type": "string",
          "enum": ["CO", "PR", "OA", "PI", "CR"]
        },
        "details": {
          "type": "array",
          "items": { "$ref": "#/$defs/AdjustmentDetail" },
          "minItems": 1,
          "maxItems": 6
        }
      },
      "required": ["groupCode", "details"]
    },

    "MedicareOutpatientAdjudicationInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "MOA segment equivalent for 837",
      "properties": {
        "esrdPaidAmount": { "type": "number", "description": "Changed from string to number" },
        "hcpcsPayableAmount": { "type": "number", "description": "Changed from string to number" },
        "outpatientReimbursementRate": { "type": "number", "description": "Changed from string to number" },
        "professionalComponent": { "type": "number", "description": "Changed from string to number" },
        "remarkCodes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 5,
          "description": "Normalized from remarkCode1/remarkCode2 into array"
        }
      },
      "required": ["esrdPaidAmount", "hcpcsPayableAmount", "outpatientReimbursementRate", "professionalComponent", "remarkCodes"]
    },

    "OtherInsuranceCoverageInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assignmentOfBenefitsIndicator": { "type": "string" },
        "releaseOfInformationCode": { "type": "string" }
      },
      "required": ["assignmentOfBenefitsIndicator", "releaseOfInformationCode"]
    },

    "OtherPayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "anyOf": [
            { "$ref": "#/$defs/Address" },
            { "type": "null" }
          ],
          "default": null
        },
        "claimAdjudicationDate": {
          "anyOf": [
            { "$ref": "#/$defs/DateWithFormat" },
            { "type": "null" }
          ],
          "default": null
        },
        "claimControlNumber": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        },
        "name": { "$ref": "#/$defs/OrganizationEntity" },
        "priorAuthorizationNumber": {
          "anyOf": [
            { "$ref": "#/$defs/ReferenceIdentifier" },
            { "type": "null" }
          ],
          "default": null
        }
      },
      "required": ["name"]
    },

    "OtherSubscriber": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": { "$ref": "#/$defs/Address" },
        "name": { "$ref": "#/$defs/PersonEntity" }
      },
      "required": ["address", "name"]
    },

    "OtherSubscriberSubscriberInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claimFilingIndicatorCode": { "type": "string" },
        "groupOrPlanName": { "type": ["string", "null"], "default": null },
        "groupOrPolicyNumber": { "type": ["string", "null"], "default": null },
        "payerSeqCode": { "type": "string" },
        "relationshipCode": { "type": "string" }
      },
      "required": ["claimFilingIndicatorCode", "payerSeqCode", "relationshipCode"]
    },

    "HeaderInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Transaction set header information",
      "properties": {
        "functionalGroup": { "$ref": "#/$defs/FunctionalGroup" },
        "hierarchicalStructureCode": { "type": "string" },
        "interchange": { "$ref": "#/$defs/Interchange" },
        "receiverInfo": { "$ref": "#/$defs/ReceiverInfo" },
        "referenceId": { "type": "string" },
        "submitterInfo": { "$ref": "#/$defs/SubmitterInfo" },
        "transactionSetControlNumber": { "type": "string" },
        "transactionSetConventionRef": { "type": "string" },
        "transactionSetCreationDate": { "type": "string", "format": "date" },
        "transactionSetCreationTime": { "type": "string" },
        "transactionSetIdCode": { "type": "string" },
        "transactionSetPurposeCode": { "type": "string" },
        "transactionTypeCode": { "type": "string", "description": "Fixed casing: was transactiontypeCode" }
      },
      "required": ["functionalGroup", "hierarchicalStructureCode", "interchange", "receiverInfo", "referenceId", "submitterInfo", "transactionSetControlNumber", "transactionSetConventionRef", "transactionSetCreationDate", "transactionSetCreationTime", "transactionSetIdCode", "transactionSetPurposeCode", "transactionTypeCode"]
    },

    "FunctionalGroup": {
      "type": "object",
      "additionalProperties": false,
      "description": "GS segment - Functional group header",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "groupControlNumber": { "type": "string" },
        "idCode": { "type": "string" },
        "responsibleAgencyCode": { "type": "string" },
        "time": { "type": "string" },
        "versionIDCode": { "type": "string" }
      },
      "required": ["date", "groupControlNumber", "idCode", "responsibleAgencyCode", "time", "versionIDCode"]
    },

    "Interchange": {
      "type": "object",
      "additionalProperties": false,
      "description": "ISA segment - Interchange control header",
      "properties": {
        "acknowledgmentRequested": { "type": "string" },
        "authorizationInfo": { "type": "string" },
        "authorizationInfoType": { "type": "string" },
        "controlNumber": { "type": "string" },
        "controlVersionNumber": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "elementSeparator": { "type": "string" },
        "receiverId": { "type": "string" },
        "receiverIdType": { "type": "string" },
        "repetitionSeparator": { "type": "string", "description": "Fixed typo: was repititionSeparator" },
        "securityInfo": { "type": "string" },
        "securityInfoType": { "type": "string" },
        "segmentTerminator": { "type": "string" },
        "senderId": { "type": "string" },
        "senderIdType": { "type": "string" },
        "subElementSeparator": { "type": "string" },
        "time": { "type": "string" },
        "usageIndicator": { "type": "string" }
      },
      "required": ["acknowledgmentRequested", "authorizationInfo", "authorizationInfoType", "controlNumber", "controlVersionNumber", "date", "elementSeparator", "receiverId", "receiverIdType", "repetitionSeparator", "securityInfo", "securityInfoType", "segmentTerminator", "senderId", "senderIdType", "subElementSeparator", "time", "usageIndicator"]
    },

    "ReceiverInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/OrganizationEntity" }
      },
      "required": ["name"]
    },

    "SubmitterInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contactInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedContactInfo" }
        },
        "name": { "$ref": "#/$defs/OrganizationEntity" }
      },
      "required": ["contactInfo", "name"]
    }
  }
}
